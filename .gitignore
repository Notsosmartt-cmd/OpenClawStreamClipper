# ============================================================
# Secrets & credentials
# ============================================================
.env
config/openclaw.json
config/openclaw.json.bak*
config/exec-approvals.json
# Dashboard runtime state — the Originality panel rewrites this on every toggle,
# so tracking it turned each settings change into a spurious "config change" that
# tripped the wiki Stop-hook. The committed default lives in
# config/originality.example.json; the dashboard falls back to DEFAULT_ORIGINALITY
# (dashboard/_state.py) when the file is absent and recreates it on first save.
config/originality.json

# ============================================================
# VODs — large video files (multi-GB each)
# ============================================================
vods/*
!vods/.gitkeep
!vods/.transcriptions/
# Transcription cache — large JSON/SRT per VOD
vods/.transcriptions/*

# ============================================================
# Generated clips — output videos + diagnostics
# ============================================================
clips/*
!clips/.gitkeep

# ============================================================
# OpenClaw runtime data (sessions, auth, memory, device IDs)
# ============================================================
config/agents/
config/identity/
config/devices/
config/logs/
config/memory/
config/canvas/
config/workspace/
config/update-check.json

# ============================================================
# Claude Code / Claude Cache
# ============================================================
.claude/
.claude-*

# Workspace runtime state
workspace/.openclaw/

# ============================================================
# Pipeline temp files (created at runtime in container)
# ============================================================
/tmp/clipper/
*.log

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/

# ============================================================
# Bare-metal Windows (native, no Docker)
# ============================================================
# Python venv — multi-GB; recreate from requirements-windows.txt
.venv/
# Local model caches — recreate on first pipeline run
models/whisper/
models/piper/
models/sentence-transformers/
# Validation test artifacts
test_gate.wav
diar_sample.wav
diar_full_out.*

# ============================================================
# Node
# ============================================================
node_modules/
package-lock.json

# ============================================================
# OS junk
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# Asset library binaries (regenerable via scripts/seed_libraries.py)
# Manifests, README, and the fetch script itself stay in git.
# ============================================================
assets/sfx/**/*.wav
assets/sfx/**/*.mp3
assets/sfx/**/*.ogg
assets/sfx/**/*.flac
assets/music/**/*.mp3
assets/music/**/*.wav
assets/music/**/*.ogg
assets/music/**/*.flac
assets/broll/**/*.mp4
assets/broll/**/*.webm
assets/broll/**/*.mov
assets/memes/**/*.png
assets/memes/**/*.jpg
assets/memes/**/*.jpeg
assets/memes/**/*.gif
assets/memes/**/*.webp
# Keep manifests, README, caption-style templates
!assets/**/library.json
!assets/README.md
!assets/caption_styles/**

# ============================================================
# Reference clips — curated competitor/source clips for clip-forensics
# (concepts/plan-clip-forensics). Media is large/binary → ignored; the
# README and human-authored .notes.json annotations stay in git.
# ============================================================
reference_clips/*.mp4
reference_clips/*.mov
reference_clips/*.webm
reference_clips/*.mkv
reference_clips/*.m4v

# ============================================================
# Reference / scratch (not part of this project)
# ============================================================
# VideoToText-main is a separate repo dropped in as reference for the bare-metal
# migration — it has its own .venv with thousands of files. Never commit it.
VideoToText-main/
config/openclaw.json.last-good
config/plugin-runtime-deps/

# ============================================================
# Deprecated / old files
# ============================================================
OpenClawStreamClipper/
OpenClaw_Stream_Clipper_Summary.md

# Imported design handoff staging (screenshots, zip, source mockups)
_design_handoff/

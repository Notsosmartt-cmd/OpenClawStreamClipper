FROM ubuntu:22.04

# Ollama environment — overridable at runtime via docker-compose environment:
ENV DEBIAN_FRONTEND=noninteractive
ENV OLLAMA_HOST=0.0.0.0
ENV OLLAMA_KEEP_ALIVE=5m
ENV OLLAMA_CONTEXT_LENGTH=32768
ENV OLLAMA_MAX_LOADED_MODELS=1
ENV OLLAMA_FLASH_ATTENTION=1

# Apt retry config — prevents flaky Docker BuildKit network failures on WSL2
RUN echo 'Acquire::Retries "5";' > /etc/apt/apt.conf.d/80-retries \
    && echo 'Acquire::http::Timeout "30";' >> /etc/apt/apt.conf.d/80-retries \
    && echo 'Acquire::https::Timeout "30";' >> /etc/apt/apt.conf.d/80-retries \
    && apt-get update && apt-get install -y --no-install-recommends \
        curl wget ca-certificates python3 zstd \
        # Vulkan loader + debug tools (vulkaninfo for device enumeration checks)
        libvulkan1 vulkan-tools \
        # Mesa Vulkan drivers — DZN (D3D12) ICD for WSL2 AMD, RADV for native Linux
        mesa-vulkan-drivers \
        # DRM/DRI runtime libraries for device access
        libdrm2 \
        libdrm-amdgpu1 \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama — ships with CUDA, Vulkan (llama.cpp), and CPU backends
RUN curl -fsSL https://ollama.com/install.sh | sh

COPY scripts/entrypoint-ollama.sh /entrypoint-ollama.sh
RUN sed -i 's/\r$//' /entrypoint-ollama.sh && chmod +x /entrypoint-ollama.sh

EXPOSE 11434

HEALTHCHECK --interval=60s --timeout=10s --start-period=60s --retries=10 \
    CMD ollama list || exit 1

ENTRYPOINT ["/entrypoint-ollama.sh"]
